rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Beta de pruebas: acceso solo para usuarios autenticados.
    // Ajustar luego por coleccion/rol si queres permisos mas finos.
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
